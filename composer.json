{
    "name": "bytetcore/queue-unique-runner",
    "version": "1.0.3",
    "description": "Ensure Laravel queue jobs run on only one server instance at a time with database or Redis distributed locking, heartbeat, and crash recovery.",
    "keywords": [
        "laravel",
        "queue",
        "job",
        "unique-runner",
        "distributed-lock",
        "mutex",
        "heartbeat",
        "crash-recovery"
    ],
    "type": "library",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "ByteTCore",
            "email": "tuando.0598@gmail.com"
        }
    ],
    "support": {
        "email": "tuando.0598@gmail.com",
        "issues": "https://github.com/ByteTCore/queue-unique-runner/issues",
        "wiki": "https://github.com/ByteTCore/queue-unique-runner/wiki",
        "source": "https://github.com/ByteTCore/queue-unique-runner",
        "docs": "https://github.com/ByteTCore/queue-unique-runner"
    },
    "require": {
        "php": "^8.0",
        "illuminate/contracts": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/queue": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "1.0",
        "orchestra/testbench": "^7.0|^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^9.6|^10.5|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Bytetcore\\QueueUniqueRunner\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bytetcore\\QueueUniqueRunner\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bytetcore\\QueueUniqueRunner\\QueueUniqueRunnerServiceProvider"
            ]
        }
    },
    "scripts": {
    "test": "vendor/bin/phpunit",
    "format": "vendor/bin/pint",
    "format-check": "vendor/bin/pint --test"
  },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}